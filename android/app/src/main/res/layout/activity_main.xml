<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- App Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:layout_marginBottom="32dp" />

        <!-- Status -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_inactive"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- Toggle Button -->
        <Button
            android:id="@+id/toggleButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/action_start"
            android:textSize="18sp"
            android:layout_marginBottom="16dp" />

        <!-- Schedule Button -->
        <Button
            android:id="@+id/scheduleButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/schedule_activation"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginBottom="16dp" />

        <!-- Schedule Section (hidden by default) -->
        <LinearLayout
            android:id="@+id/scheduleSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:padding="16dp"
            android:background="@drawable/schedule_background">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/start_date"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/scheduleStartText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="\u2014"
                    android:textSize="16sp"
                    android:gravity="center_vertical" />

                <Button
                    android:id="@+id/scheduleStartButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/choose"
                    style="@style/Widget.MaterialComponents.Button.TextButton" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/end_date"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/scheduleEndText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="\u2014"
                    android:textSize="16sp"
                    android:gravity="center_vertical" />

                <Button
                    android:id="@+id/scheduleEndButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/choose"
                    style="@style/Widget.MaterialComponents.Button.TextButton" />
            </LinearLayout>

            <Button
                android:id="@+id/scheduleConfirmButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/confirm_schedule" />
        </LinearLayout>

        <!-- Spacer -->
        <View
            android:layout_width="1dp"
            android:layout_height="32dp" />

        <!-- Navigation Buttons -->
        <Button
            android:id="@+id/historyButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/nav_history"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/permissionsButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/nav_permissions"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
    </LinearLayout>
</ScrollView>
